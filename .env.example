APP_ENV=development
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot
REDIS_URL=redis://localhost:6379/0
EVENT_STREAM=whatsapp_messages
EVENT_DLQ_STREAM=whatsapp_messages_dlq
CONSUMER_GROUP=chatbot_workers
MAX_EVENT_RETRIES=3
DEDUPLICATION_TTL_SECONDS=86400
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_PROMPT_VERSION=intent-router-v1
LLM_MINIMUM_CONFIDENCE=0.72
TENANT_SECRET_KEY=
UPLOAD_DIR=/tmp/chatbot_uploads
MAX_UPLOAD_BYTES=10485760
